# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules

# Bun: no versionar lock antiguo (desalineado con package.json rompe Cloudflare `bun install --frozen-lockfile`).
# El repo usa `package-lock.json` para CI / Workers Builds con npm.
/bun.lock
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (mantener .env.example en el repo)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Secreto del puente Justicia XXI (alternativa si no está en .env)
.judicialsys-bridge-secret

# vercel
.vercel

# Wrangler local (cache de build / deploy)
.wrangler/

# Script de depuración local (contiene host interno)
scripts/tmp-mssql-config.js

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
dev.log
test
prompt

server.log
# Skills directory
/skills/

# Scripts locales / logs
.zscripts/*.log
.zscripts/dev.pid
/3001

# Base de datos local (no subir datos reales)
*.db
*.db-journal
/prisma/dev.db*

# Informes de inspección BD (pueden contener datos sensibles)
/scripts/reports/

# Archivos subidos en desarrollo
/uploads/*
!/uploads/.gitkeep
!/uploads/ejemplos/
!/uploads/ejemplos/**
/upload/*