DATABASE_URL="file:./prisma/dev.db"

# Opcional: Para importar reparto con IA (OpenAI GPT-4o-mini) y mayor precisión al leer documentos
# OPENAI_API_KEY="sk-..."

# Bucket S3 para documentos (AWS S3 o MinIO compatible)
# Si no se configura, los archivos se guardan en uploads/ en disco local
# S3_BUCKET=judicial-expedientes
# S3_REGION=us-east-1
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_PREFIX=expedientes
# Para MinIO local: S3_ENDPOINT=http://localhost:9000
