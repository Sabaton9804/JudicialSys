# Copie este archivo a .env.local y rellene (.env.local no se sube a git).
# Usuario y contraseña del portal SGDE (mismos que para Crear expediente en JudicialSys).

SGDE_USER=
SGDE_PASSWORD=
# SQLite local (Prisma). Ajuste la ruta si usa otro archivo.
DATABASE_URL="file:./dev.db"


# Justicia XXI / BD Consejo (SQL Server) — radicación T103/T110 desde JudicialSys
# JUSTICIA_XXI_SQL_ENABLED=true
# Opción A: cadena completa
# JUSTICIA_XXI_SQL_CONNECTION_STRING=Server=...;Database=consejo;User Id=...;Password=...;Encrypt=true;TrustServerCertificate=true
# Opción B: piezas
# JUSTICIA_XXI_SQL_SERVER=localhost
# JUSTICIA_XXI_SQL_USER=
# JUSTICIA_XXI_SQL_PASSWORD=
# JUSTICIA_XXI_SQL_DATABASE=consejo
# JUSTICIA_XXI_SQL_ENCRYPT=true
# JUSTICIA_XXI_SQL_TRUST_CERT=true
# Origen CUI (opcional; si no, se deduce del radicado de 23 dígitos)
# JUSTICIA_XXI_ORIGEN_CODICIUO=
# JUSTICIA_XXI_ORIGEN_CODIENTO=
# JUSTICIA_XXI_ORIGEN_CODIESPO=
# JUSTICIA_XXI_ORIGEN_CODINUMO=

# Justicia XXI (SQL): puede usar solo el formulario en la app (usuario/contraseña/servidor).
# Opcional en .env: servidor y/o contraseña por defecto si no los escribe en pantalla.
# JUSTICIA_XXI_SQL_SERVER=
# JUSTICIA_XXI_SQL_DATABASE=consejo
# JUSTICIA_XXI_SQL_USER=
# JUSTICIA_XXI_SQL_PASSWORD=
# O cadena completa (si no usa el formulario):
# JUSTICIA_XXI_SQL_CONNECTION_STRING=Server=...;Database=consejo;...
